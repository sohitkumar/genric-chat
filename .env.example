# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
#
# Get your OpenAI API key from: https://platform.openai.com/api-keys

OPENAI_API_KEY=sk-your-key-here
MODEL_NAME=gpt-4o-mini

# PostgreSQL (SQLAlchemy + psycopg3). On the same host as the API use localhost or 127.0.0.1.
# DATABASE_URL=postgresql+psycopg://USER:PASSWORD@localhost:5432/DBNAME
DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/dbname

# Public URL where this API is reachable (browser/OpenAPI). Example on EC2: http://YOUR_IP:8000
# API_PUBLIC_URL=http://127.0.0.1:8000

# Origins allowed to call the API from the browser (comma-separated), or * for any.
# Example: CORS_ORIGINS=http://YOUR_IP:3000,https://yourdomain.com
# CORS_ORIGINS=*
